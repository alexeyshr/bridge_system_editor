# Environment template for local development.
# Copy to .env.local and fill with your values.

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bridge_editor?schema=public"

# Auth.js
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# Telegram login
TELEGRAM_BOT_TOKEN="replace-with-telegram-bot-token"
TELEGRAM_BOT_NAME="replace-with-bot-username"
NEXT_PUBLIC_TELEGRAM_BOT_NAME="replace-with-bot-username-without-at"

# Optional email delivery for invite links
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@example.com"

# API transport
# Options: rest | trpc
API_TRANSPORT="trpc"

# Remote DB tunnel (for running local CLI against VPS-local Postgres)
REMOTE_DB_SSH_HOST=""
REMOTE_DB_SSH_PORT="22"
REMOTE_DB_SSH_USER=""
REMOTE_DB_SSH_PASSWORD=""
REMOTE_DB_SSH_HOSTKEY=""
REMOTE_DB_SSH_FORCE_PLINK="false"
REMOTE_DB_PLINK_PATH="C:\\Program Files\\PuTTY\\plink.exe"
REMOTE_DB_TUNNEL_LOCAL_PORT="15433"
REMOTE_DB_REMOTE_HOST="127.0.0.1"
REMOTE_DB_REMOTE_PORT="5433"
