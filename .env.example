# Environment template for local development.
# Copy to .env.local and fill with your values.

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bridge_editor?schema=public"

# Auth.js
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# Telegram login
TELEGRAM_BOT_TOKEN="replace-with-telegram-bot-token"
TELEGRAM_BOT_NAME="replace-with-bot-username"

# Optional email delivery for invite links
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@example.com"

# API transport
# Options: rest | trpc
API_TRANSPORT="trpc"
