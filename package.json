{
  "name": "bridge-system-editor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/dev-auto.ts",
    "dev:local": "next dev",
    "dev:remote": "tsx scripts/run-with-db-tunnel.ts -- npm run dev:local",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --test --import tsx",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('.next',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true});\"",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:migrate:remote": "tsx scripts/run-with-db-tunnel.ts migrate",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "db:healthcheck": "tsx scripts/db-healthcheck.ts",
    "db:healthcheck:remote": "tsx scripts/run-with-db-tunnel.ts healthcheck",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:seed:remote": "tsx scripts/run-with-db-tunnel.ts seed",
    "db:ingest:bridgesport": "tsx scripts/ingest-bridgesport.ts",
    "db:ingest:bridgesport:remote": "tsx scripts/run-with-db-tunnel.ts ingest-bridgesport",
    "db:reload:player-tournaments": "tsx scripts/reload-player-tournaments.ts",
    "db:reload:player-tournaments:remote": "tsx scripts/run-with-db-tunnel.ts -- npm run db:reload:player-tournaments",
    "ui:baseline": "node scripts/run-ui-baseline-check.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@hookform/resolvers": "^5.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.12.0",
    "@trpc/react-query": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "@types/js-yaml": "^4.0.9",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "next-auth": "^4.24.13",
    "postcss": "^8.5.6",
    "postgres": "^3.4.8",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-resizable-panels": "^4.7.1",
    "shadcn": "^4.0.2",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "playwright": "^1.58.2",
    "tailwindcss": "4.1.11",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}
